@model MVC_WEB_APP.ViewModels.UsersVm.LoginVm

<section class="breadcrumb-section">
	<h2 class="sr-only">Site Breadcrumb</h2>
	<div class="container">
		<div class="breadcrumb-contents">
			<nav aria-label="breadcrumb">
				<ol class="breadcrumb">
					<li class="breadcrumb-item"><a href="index.html">Home</a></li>
					<li class="breadcrumb-item active">Login</li>
				</ol>
			</nav>
		</div>
	</div>
</section>
<!--=============================================
=            Login Register page content         =
=============================================-->
<main class="page-section inner-page-sec-padding-bottom">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-sm-12 col-md-12 col-xs-12 col-lg-6 mb--30 mb-lg--0 text-center">
				<!-- Login Form s-->
				<form asp-action="Login" method="post">
					<div class="login-form">
						<h4 class="login-title">Login</h4>
						<p><span class="font-weight-bold">I am a returning customer</span></p>
						<div asp-validation-summary="ModelOnly" class="text-danger"></div>
						<div class="row">
							<div class="col-md-12 col-12 mb--15">
								<label asp-for="UsernameorEmail"></label>
								<input asp-for="UsernameorEmail" class="mb-0 form-control" placeholder="Enter your username or email">
								<span asp-validation-for="UsernameorEmail" class="text-danger"></span>
							</div>

							<div class="col-lg-6 mb--20">
								<label asp-for="Password">Password</label>
								<input asp-for="Password" class="mb-0 form-control" placeholder="Enter your password">
								<span asp-validation-for="Password" class="text-danger"></span>
							</div>
							<div class="">
								<label asp-for="RememberMe"></label>
								<input asp-for="RememberMe" class="">
							</div>
							<div class="col-md-12">
								<button type="submit" class="btn btn-outlined">Login</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</main>
@section scripts {
	<partial name="_ValidationScriptsPartial" />

}