@using static System.Reflection.Metadata.BlobBuilder
@model List<Book>
@foreach (var book in Model)
{
    <div class="single-slide">
        <div class="product-card">
            <div class="product-header">
                <a href="#" class="author">
                    @book.Author.FullName
                </a>
                <h3>
                    <a asp-controller="Books" asp-action="Detail" asp-route-id="@book.Id">
                        @book.Name
                    </a>
                </h3>
            </div>
            <div class="product-card--body">
                <div class="card-image">
                    <img src="~/assets/image/products/@book.MainImageUrl" alt="">
                    <div class="hover-contents">
                        <a asp-controller="Books" asp-action="Detail" asp-route-id="@book.Id" class="hover-image">
                            <img src="~/assets/image/products/@book.HoverImageUrl" alt="">
                        </a>
                        <div class="hover-btns">
                            <a asp-controller="basket" asp-action="addbasket" asp-route-id="@book.Id" class="single-btn addbasket">
                                <i class="fas fa-shopping-basket"></i>
                            </a>
                            <a href="wishlist.html" class="single-btn">
                                <i class="fas fa-heart"></i>
                            </a>
                            <a href="compare.html" class="single-btn">
                                <i class="fas fa-random"></i>
                            </a>
                            <a asp-action="BookModal" asp-controller="books" asp-route-id="@book.Id" class="bookModalIcon">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="price-block">
                    @if (book.DiscountPercentage > 0)
                    {
                        <span class="price">£@(book.Price - (book.Price * book.DiscountPercentage) / 100)</span>
                        <del class="price-old">£@book.Price</del>
                        <span class="price-discount">@book.DiscountPercentage%</span>
                    }
                    else
                    {
                        <span class="price">£@book.Price</span>
                    }
                </div>
            </div>
        </div>
    </div>
}