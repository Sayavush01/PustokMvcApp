@model IEnumerable<PustokMvcApp.Models.Slider>
@{
    ViewData["Title"] = "Sliders";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Sliders List</h6>
        <div>
            <a asp-action="GenerateFake" asp-area="Manage" asp-controller="Slider" class="btn btn-info btn-sm mr-2">
                <i class="fas fa-magic"></i> Generate Random Sliders
            </a>
            <a asp-action="Create" class="btn btn-primary btn-sm">Create New Slider</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Button Text</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    @if(!string.IsNullOrEmpty(item.ImageUrl)) {
                                        <img src="~/assets/image/bg-images/@item.ImageUrl" alt="Slider Image" style="max-width: 100px;" />
                                    } else {
                                        <span class="text-muted">No Image</span>
                                    }
                                </td>
                                <td>@item.Title</td>
                                <td>@item.ButtonText</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm deleteSlider">Delete</a>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr>
                            <td colspan="5" class="text-center">No sliders found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Include SweetAlert2 from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // Handle SweetAlert Delete
            $('.deleteSlider').click(function (e) {
                e.preventDefault();
                
                // Capture the URL before entering the SweetAlert callback
                var url = $(this).attr('href');
                
                Swal.fire({
                    title: "Do you want to delete this slider?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, delete it!",
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6"
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: url,
                            type: "get", // Using generic HTTP GET for deletion just like in authors
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire("Slider deleted successfully!", "", "success").then(() => {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire("Error deleting slider", response.message || "An unexpected error occurred.", "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error deleting slider", "An unexpected error occurred.", "error");
                            }
                        });
                    } else if (result.isDenied) {
                        Swal.fire("Changes are not saved", "", "info");
                    }
                });
            });
        });
    </script>
}
