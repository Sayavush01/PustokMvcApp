@model MVC_WEB_APP.Areas.Manage.ViewModels.AdminLoginVm
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Admin Login - Pustok</title>
    
    <!-- Using a generic bootstrap just in case, but standard template might be different -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-primary">
    <div id="layoutAuthentication">
        <div id="layoutAuthentication_content">
            <main>
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-lg-7 col-md-9">
                            <div class="card shadow-lg border-0 rounded-lg mt-5">
                                <div class="card-header"><h3 class="text-center font-weight-light my-4">Login</h3></div>
                                <div class="card-body">
                                    <form asp-action="Login" method="post">
                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                        <div class="form-floating mb-3">
                                            <input asp-for="Username" class="form-control" id="inputUsername" placeholder="Username" />
                                            <label for="inputUsername">Username</label>
                                            <span asp-validation-for="Username" class="text-danger"></span>
                                        </div>
                                        <div class="form-floating mb-3">
                                            <input asp-for="Password" class="form-control" id="inputPassword" placeholder="Password" />
                                            <label for="inputPassword">Password</label>
                                            <span asp-validation-for="Password" class="text-danger"></span>
                                        </div>
                                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0 gap-3">
                                            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-50">Back to Home</a>
                                            <button type="submit" class="btn btn-primary w-50">Login</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</body>
</html>
