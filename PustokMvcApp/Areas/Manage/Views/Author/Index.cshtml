@model IEnumerable<PustokMvcApp.Models.Author>
@{
    ViewData["Title"] = "Authors";
}

<div class="card shadow mb-4">
<div class="card-header py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-primary">Authors List</h6>
    <div>
        <form asp-action="GenerateFake" method="post" class="d-inline">
            <button type="submit" class="btn btn-info btn-sm mr-2">
                <i class="fas fa-magic"></i> Generate Random Authors
            </button>
        </form>
        <a asp-action="Create" class="btn btn-primary btn-sm">Create New Author</a>
    </div>
</div>
<div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Full Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.FullName</td>
                                <td>
                                    <button type="button" data-url="@Url.Action("DetailsModal", "Author", new { id = item.Id })" class="btn btn-info btn-sm show-details-modal">Modal Details</button>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm deleteAuthor">Delete</a>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr>
                            <td colspan="3" class="text-center">No authors found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<!-- Include SweetAlert2 from CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
<!-- Modal Container -->
<div class="modal fade" id="authorModal" tabindex="-1" role="dialog" aria-labelledby="authorModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content" id="authorModalContent">
            <!-- Content will be loaded here via Ajax -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        // Handle Modal Details Clicks
        $(document).on('click', '.show-details-modal', function (e) {
            e.preventDefault();
            var url = $(this).data('url');
            $.get(url, function (data) {
                $('#authorModalContent').html(data);
                $('#authorModal').modal('show');
            });
        });

        // Handle SweetAlert Delete
        $('.deleteAuthor').click(function (e) {
            e.preventDefault();
            
            // Capture the URL before entering the SweetAlert callback
            var url = $(this).attr('href');
            
            Swal.fire({
                title: "Do you want to delete this author?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, delete it!",
                confirmButtonColor: "#d33",
                cancelButtonColor: "#3085d6"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: url,
                        type: "get", // Your controller action might need to be modified if it expects POST
                        success: function () {
                            Swal.fire("Author deleted successfully!", "", "success").then(() => {
                                location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire("Error deleting author", "An unexpected error occurred.", "error");
                        }
                    });
                } else if (result.isDenied) {
                    Swal.fire("Changes are not saved", "", "info");
                }
            });
        });
    });
</script>
}

