@model PustokMvcApp.Models.Author
@{
    ViewData["Title"] = "Author Details";
}

<div class="card shadow mb-4 col-md-8 mx-auto">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Author Details - @Model.FullName</h6>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID Number</dt>
            <dd class="col-sm-9 text-muted">@Model.Id</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9"><strong>@Model.FullName</strong></dd>
        </dl>
    </div>
    <div class="card-footer bg-white text-center">
        <a asp-action="Index" class="btn btn-secondary mr-2">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit Author
        </a>
    </div>
</div>
