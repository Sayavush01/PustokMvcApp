@model PustokMvcApp.Models.Author
@{
    ViewData["Title"] = "Create Author";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Create New Author</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="FullName" class="control-label font-weight-bold">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name..." />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="form-group mt-4 text-center">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Create
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
