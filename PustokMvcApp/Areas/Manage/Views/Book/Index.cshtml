@model IEnumerable<PustokMvcApp.Models.Book>
@{
    ViewData["Title"] = "Books";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Books List</h6>
        <div>
            <a asp-action="GenerateFake" asp-area="Manage" asp-controller="Book" class="btn btn-info btn-sm mr-2">
                <i class="fas fa-magic"></i> Generate Random Books
            </a>
            <a asp-action="Create" class="btn btn-primary btn-sm">Create New Book</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered text-center align-middle" width="100%" cellspacing="0">
                <thead>
                    <tr class="text-secondary">
                        <th class="text-left">Image</th>
                        <th class="text-left">Name</th>
                        <th class="text-left">Author</th>
                        <th class="text-left">Code</th>
                        <th class="text-left">Price</th>
                        <th class="text-left">In Stock</th>
                        <th class="text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-left" style="width: 80px;">
                                    @if(!string.IsNullOrEmpty(item.MainImageUrl)) {
                                        <img src="~/assets/image/products/@item.MainImageUrl" alt="Book Image" style="max-width: 50px; border-radius: 4px; box-shadow: 0 0 5px rgba(0,0,0,0.1);" />
                                    } else {
                                        <span class="text-muted">No Image</span>
                                    }
                                </td>
                                <td class="text-left align-middle text-muted font-weight-bold" style="font-size: 1.1rem;">@item.Name</td>
                                <td class="text-left align-middle text-muted font-weight-bold" style="font-size: 1.1rem;">@(item.Author?.FullName ?? "Unknown")</td>
                                <td class="text-left align-middle text-muted font-weight-bold" style="font-size: 1.1rem;">book@item.Code</td>
                                <td class="text-left align-middle text-muted font-weight-bold" style="font-size: 1.1rem;">$@item.Price.ToString("0.00").Replace(".", ",")</td>
                                <td class="text-left align-middle">
                                    @if (item.InStock)
                                    {
                                        <span class="badge bg-success text-white px-3 py-1" style="font-size: 0.9rem; border-radius: 4px;">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white px-3 py-1" style="font-size: 0.9rem; border-radius: 4px;">No</span>
                                    }
                                </td>
                                <td class="text-left align-middle">
                                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-white font-weight-bold shadow-sm">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white font-weight-bold shadow-sm px-3">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm text-white font-weight-bold shadow-sm px-3 deleteBook">Delete</a>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr>
                            <td colspan="7" class="text-center">No books found in the database.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('.deleteBook').click(function(e) {
                e.preventDefault();
                
                var url = $(this).attr('href');
                
                Swal.fire({
                    title: "Do you want to delete this Book?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, delete it!",
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6"
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: url,
                            type: "get",
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire("Book deleted successfully!", "", "success").then(() => {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire("Error deleting book", response.message || "An error occurred.", "error");
                                }
                            },
                            error: function () {
                                Swal.fire("Error deleting book", "An unexpected error occurred.", "error");
                            }
                        });
                    }
                });
            });
        });
    </script>
}
