@model PustokMvcApp.Models.Book
@{
    ViewData["Title"] = "Book Details";
}

<div class="card shadow mb-4 col-md-10 mx-auto px-0">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Book Details - @Model.Name</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 text-center">
                @if(!string.IsNullOrEmpty(Model.MainImageUrl)) {
                    <img src="~/assets/image/products/@Model.MainImageUrl" alt="Main Cover" class="img-fluid rounded shadow-sm mb-3" style="max-height: 350px;" />
                } else {
                    <div class="text-muted p-5 border rounded mb-3">No Main Image</div>
                }
            </div>
            <div class="col-md-8">
                <dl class="row mb-0" style="font-size: 1.1rem;">
                    <dt class="col-sm-4 text-muted">ID System</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted mt-2">Book Name</dt>
                    <dd class="col-sm-8 mt-2 text-dark font-weight-bold">@Model.Name</dd>
                    
                    <dt class="col-sm-4 text-muted mt-2">Author</dt>
                    <dd class="col-sm-8 mt-2">@(Model.Author?.FullName ?? "Unknown")</dd>

                    <dt class="col-sm-4 text-muted mt-2">Price</dt>
                    <dd class="col-sm-8 mt-2 text-success font-weight-bold">$@Model.Price.ToString("0.00").Replace(".", ",")</dd>

                    <dt class="col-sm-4 text-muted mt-2">Discount</dt>
                    <dd class="col-sm-8 mt-2">@Model.DiscountPercentage%</dd>

                    <dt class="col-sm-4 text-muted mt-2">In Stock</dt>
                    <dd class="col-sm-8 mt-2">
                        @if(Model.InStock) {
                            <span class="badge bg-success text-white px-2 py-1">Available</span>
                        } else {
                            <span class="badge bg-danger text-white px-2 py-1">Sold Out</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted mt-2">Tags</dt>
                    <dd class="col-sm-8 mt-2">
                        @if(Model.BookTags != null && Model.BookTags.Any()) {
                            foreach(var bookTag in Model.BookTags) {
                                <span class="badge bg-secondary text-white mr-1 mb-1">@bookTag.Tag?.Name</span>
                            }
                        } else {
                            <span class="text-muted font-italic">No tags assigned.</span>
                        }
                    </dd>
                </dl>

                <hr />
                <h6 class="text-muted font-weight-bold mt-4">Description Text:</h6>
                <p class="text-dark bg-light p-3 rounded shadow-sm">
                    @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                </p>
            </div>
        </div>

        @if(Model.BookImages != null && Model.BookImages.Any()) {
            <hr />
            <h6 class="text-primary font-weight-bold mt-3 mb-3">Additional Images Gallery (@Model.BookImages.Count files)</h6>
            <div class="row text-center">
                @foreach(var img in Model.BookImages) {
                    <div class="col-md-2 col-sm-4 mb-3">
                        <img src="~/assets/image/products/@img.Image" class="img-fluid rounded border shadow-sm" alt="Gallery Image" />
                    </div>
                }
            </div>
        }
    </div>
    
    <div class="card-footer text-center bg-white border-top-0 pt-0 pb-4">
        <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">
            <i class="fas fa-arrow-left mr-1"></i> Back to List
        </a>
        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning px-4 ml-2 shadow-sm text-white font-weight-bold">
            <i class="fas fa-edit mr-1"></i> Edit Book
        </a>
    </div>
</div>