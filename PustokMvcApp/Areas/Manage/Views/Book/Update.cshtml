@model PustokMvcApp.Models.Book
@{
    ViewData["Title"] = "Edit Book";
    var authors = ViewBag.Authors as List<PustokMvcApp.Models.Author>;
    var tags = ViewBag.Tags as List<PustokMvcApp.Models.Tag>;
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow mb-4">
            <div class="card-body">
                <form asp-action="Update" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Name" class="control-label font-weight-bold">Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="AuthorId" class="control-label font-weight-bold">Author</label>
                                <select asp-for="AuthorId" class="form-control" asp-items="@(new SelectList(authors, "Id", "FullName"))">
                                    <option value="" disabled selected>-- Select an Author --</option>
                                </select>
                                <span asp-validation-for="AuthorId" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="TagIds" class="control-label font-weight-bold">Tags</label>
                                <select asp-for="TagIds" class="form-control" multiple asp-items="@(new SelectList(tags, "Id", "Name"))">
                                </select>
                                <span asp-validation-for="TagIds" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Price" class="control-label font-weight-bold">Price ($)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="DiscountPercentage" class="control-label font-weight-bold">Discount (%)</label>
                                <input asp-for="DiscountPercentage" class="form-control" type="number" min="0" max="100" />
                                <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Code" class="control-label font-weight-bold">Code</label>
                                <input asp-for="Code" class="form-control" type="number" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="MainPhoto" class="control-label font-weight-bold">Main Image File</label>
                                <input asp-for="MainPhoto" class="form-control" type="file" accept="image/*" />
                                <span asp-validation-for="MainPhoto" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="HoverPhoto" class="control-label font-weight-bold">Hover Image File</label>
                                <input asp-for="HoverPhoto" class="form-control" type="file" accept="image/*" />
                                <span asp-validation-for="HoverPhoto" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Files" class="control-label font-weight-bold">Additional Images</label>
                                <input asp-for="Files" class="form-control" type="file" accept="image/*" multiple />
                                <span asp-validation-for="Files" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3 mt-4">
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="InStock" class="custom-control-input" id="InStockCheck" />
                                    <label class="custom-control-label" for="InStockCheck">In Stock</label>
                                </div>
                                <div class="custom-control custom-checkbox mt-2">
                                    <input asp-for="IsNew" class="custom-control-input" id="IsNewCheck" />
                                    <label class="custom-control-label" for="IsNewCheck">Is New</label>
                                </div>
                                <div class="custom-control custom-checkbox mt-2">
                                    <input asp-for="IsFeatured" class="custom-control-input" id="IsFeaturedCheck" />
                                    <label class="custom-control-label" for="IsFeaturedCheck">Is Featured</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="control-label font-weight-bold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="form-group mt-4 text-center border-top pt-3">
                        <a asp-action="Index" class="btn btn-secondary mr-2">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save"></i> Update
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
